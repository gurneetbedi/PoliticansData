# ----------------------------------------------------------------------------
# ECI pipeline — exclude downloaded PDFs and regenerable intermediates.
# Source PDFs are downloaded fresh by scripts/fetch_eci_affidavits.py;
# preprocessed JSONs are regenerated by scripts/preprocess_eci_pdfs.py.
# We DO commit the schema, prompt, example output, and small index files
# under data/eci/for_ai/.
# ----------------------------------------------------------------------------
# Source PDFs (large, downloadable on demand)
data/eci/raw_pdfs/
data/eci/for_ai/pdfs/
data/eci/for_ai/preprocessed/
data/eci/for_ai/output/
data/eci/vision_demo/

